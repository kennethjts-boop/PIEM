VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_BASE_URL=https://profeia-pilot-staging-production-cecd.up.railway.app
VITE_DOCUMENTS_BACKEND=local
VITE_N8N_WEBHOOK_URL=https://your-n8n-webhook.example.com

# Modo del razonador del agente (rules | openai)
# Si es 'openai', el frontend llama a /api/agent/reason en el server
VITE_AGENT_REASONER_MODE=rules

# HGI-MX — Integración futura EVA (Tier 3)
# HGI-MX es un servicio externo. Profeia es cliente, no propietario.
# NO configurar hasta que HGI-MX esté disponible.
VITE_HGI_API_URL=
VITE_HGI_API_KEY=